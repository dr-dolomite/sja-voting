// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Section {
  id     String  @id @default(cuid())
  name   String  @unique
  voters Voter[]
}

model Voter {
  id        String    @id @default(cuid())
  lrn       String    @unique
  sectionId String
  section   Section   @relation(fields: [sectionId], references: [id])
  hasVoted  Boolean   @default(false)
  votedAt   DateTime?
  votes     Vote[]
  createdAt DateTime  @default(now())
}

model Election {
  id        String     @id @default(cuid())
  name      String
  isActive  Boolean    @default(false)
  createdAt DateTime   @default(now())
  positions Position[]
}

model Position {
  id         String      @id @default(cuid())
  name       String
  order      Int
  maxVotes   Int         @default(1)
  electionId String
  election   Election    @relation(fields: [electionId], references: [id], onDelete: Cascade)
  candidates Candidate[]
}

model Partylist {
  id         String      @id @default(cuid())
  name       String      @unique
  color      String?
  candidates Candidate[]
}

model Candidate {
  id          String    @id @default(cuid())
  fullName    String
  description String?
  imageUrl    String?
  positionId  String
  position    Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  partylistId String
  partylist   Partylist @relation(fields: [partylistId], references: [id])
  votes       Vote[]
}

model Vote {
  id          String    @id @default(cuid())
  voterId     String
  voter       Voter     @relation(fields: [voterId], references: [id])
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([voterId, candidateId])
}

// ─── Audit Logging ──────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(cuid())
  timestamp DateTime    @default(now())

  // Who performed the action
  actorType ActorType
  actorId   String?
  actorName String?

  // What happened
  action   String
  category LogCategory
  severity LogSeverity @default(INFO)

  // Context
  targetType String?
  targetId   String?
  targetName String?

  // Details
  detail   String?
  metadata Json?

  // Request context
  ipAddress String?

  @@index([timestamp])
  @@index([category])
  @@index([severity])
  @@index([actorType])
  @@index([action])
}

enum ActorType {
  ADMIN
  VOTER
  SYSTEM
}

enum LogCategory {
  AUTH
  VOTE
  ELECTION
  POSITION
  CANDIDATE
  PARTYLIST
  VOTER_MGMT
  ADMIN_MGMT
  SYSTEM
}

enum LogSeverity {
  INFO
  WARNING
  ERROR
}
